{
  "name": "uuid-lab",
  "version": "2.0.0",
  "description": "Comprehensive ID generation library — UUID, NanoID, ULID, CUID2, Snowflake, and 280+ utilities",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "uuid-lab": "./bin/uuid-lab.js"
  },
  "exports": {
    ".":        "./index.js",
    "./react":  "./react/hooks.js",
    "./vue":    "./vue/composables.js",
    "./server": "./server.js",
    "./validation": "./validation.js",
    "./compat": "./compat.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "generators.js",
    "decoder.js",
    "format.js",
    "advanced.js",
    "namespace.js",
    "timeid.js",
    "analytics.js",
    "chain.js",
    "cuid.js",
    "deterministic.js",
    "enterprise.js",
    "validation.js",
    "compat.js",
    "server.js",
    "react/",
    "vue/",
    "bin/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test":      "node test-v3.js && node test-v4.js && node test-v5.js && node test-v6.js && node test-v7.js && node test-v8.js && node test-enterprise.js && node test-nextgen.js && node test-bleeding-edge.js",
    "test:all":  "node test-all.js",
    "bench":     "node benchmark.js",
    "start":     "node server.js",
    "prepublish":"npm test"
  },
  "keywords": [
    "uuid", "nanoid", "ulid", "cuid", "cuid2", "ksuid", "snowflake",
    "id", "identifier", "generator", "unique", "random",
    "typescript", "react", "vue", "nextjs", "nuxt",
    "mongodb", "postgresql", "prisma", "typeorm",
    "collision", "entropy", "deterministic", "sha3"
  ],
  "author": "Mayur Patel <mayurpatel2781@example.com>",
  "license": "MIT",
  "engines": { "node": ">=16.0.0" },
  "repository": {
    "type": "git",
    "url":  "https://github.com/mayurpatel-2781/uuid-lab.git"
  },
  "bugs": {
    "url": "https://github.com/mayurpatel-2781/uuid-lab/issues"
  },
  "homepage": "https://github.com/mayurpatel-2781/uuid-lab#readme"
}
